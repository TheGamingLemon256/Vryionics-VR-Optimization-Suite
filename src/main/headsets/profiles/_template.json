{
  "_comment": "Copy this template to contribute a headset profile. Remove all _comment fields before submitting.",
  "_comment_filename": "Filename must be kebab-case matching the id field: 'meta-quest-3.json'",

  "id": "brand-model-name",
  "brand": "BrandName",
  "model": "Model Name",
  "type": "standalone-hybrid | tethered | standalone",
  "releaseYear": 2024,

  "display": {
    "resolutionPerEye": [0, 0],
    "refreshRates": [90],
    "panelType": "LCD | OLED | Mini-LED | Micro-OLED",
    "fov": 100
  },

  "connections": [
    {
      "id": "model-connection-id",
      "name": "Connection Display Name",
      "archetype": "tethered-dp | usb-encoded | wifi-wireless | wigig",
