      "latencyProfile": { "typical": 0, "best": 0, "worst": 0 }
    }
  ],

  "runtimes": ["steamvr"],

  "tracking": {
    "type": "inside-out | outside-in | lighthouse",
    "controllers": "Controller Name",
    "eyeTracking": false,
    "faceTracking": false,
    "bodyTracking": false
  },

  "requirements": {
    "minGPU": "GTX 1060 / RX 580",
    "recommendedGPU": "RTX 3070 / RX 6800 XT",
    "minCPU": "Intel i5-4590 / Ryzen 5 1500X",
    "minRAM": 8,
    "ports": ["List required physical ports"]
  },

  "knownIssues": [],
  "optimizationTips": [],

  "steamvrSettings": {
    "renderResolution": 1.0,
    "reprojection": "motion-smoothing | asw | none"
  }
